{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "framework": null,
  "headers": [
    {
      "source": "/(.*\\.(glb|mind|wasm|js|css|html|jpg|jpeg|png))",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ]
}
